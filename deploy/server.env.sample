# Скопируйте в .env в корне проекта на сервере:
#   cp deploy/server.env.sample .env && nano .env

# Сильный отдельный пароль для PostgreSQL (не пароль SSH root).
POSTGRES_PASSWORD=придумайте_длинный_пароль

# Сайт снаружи (на сервере — 80; локально оставьте 8010)
APP_PORT=80

# Публичный URL (для СБП callback ЭЛПЛАТ — обязательно доступен из интернета)
PUBLIC_BASE_URL=http://kafeadam.ru

# PostgreSQL только с localhost сервера, порт 8009 (удобно для бэкапов / psql по SSH)
POSTGRES_PORT_MAPPING=127.0.0.1:8009:5432

# --- Оплата СБП (НКО ЭЛПЛАТ) ---
# Документация: https://docs.google.com/document/d/e/2PACX-1vSNWj_r4nwXqD2Ne_CcPbYjp_CZDZM32DUD64xgNNbInz02kKkSU2I5Eyf1FaGnehh-j8tElvm47aDu/pub
# Тестовый шлюз: http://sbpekvtest.el-plat.ru
# Боевой (после тестов): https://sbpekv.el-plat.ru или https://sbpekv2.el-plat.ru
#
# ELPLAT_ENABLED=true
# ELPLAT_API_URL=http://sbpekvtest.el-plat.ru
# ELPLAT_LOGIN=ваш_логин
# ELPLAT_PASSWORD=ваш_пароль
# ELPLAT_ORG_ID=ваш_org_id
# ELPLAT_VERIFY_CALLBACK_IP=true

# Админ-панель
# ADMIN_USERNAME=adam_admin
# ADMIN_PASSWORD=сильный_пароль

# SESSION_SECRET=длинная_случайная_строка

# Опционально
# WEB_CONCURRENCY=2
# GUNICORN_TIMEOUT=120

# DATABASE_URL=postgresql+psycopg://postgres:ВАШ_ПАРОЛЬ@postgres:5432/adam_delivery
