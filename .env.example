# Локальная разработка (PostgreSQL в Docker на порту 5433)
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5433/adam_delivery

# Обязательно смените в продакшене (подпись сессионных cookie)
# SESSION_SECRET=длинная_случайная_строка

# Админ-панель: только логин и пароль из переменных окружения
# ADMIN_USERNAME=adam_admin
# ADMIN_PASSWORD=сильный_пароль_не_по_умолчанию

# Почта для писем клиенту о заказе (если не задано SMTP_HOST — письма не отправляются)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USE_TLS=true
# SMTP_USER=your_login
# SMTP_PASSWORD=your_password
# SMTP_FROM — только email (без «Имя <...>»). Имя — в SMTP_FROM_NAME.
# SMTP_FROM=no-reply@yandex.ru
# SMTP_FROM_NAME=Кафе «Адам»
# Проверка: python scripts/test_smtp.py  или  python scripts/test_smtp.py --send you@mail.ru

# --- Продакшен / Docker Compose ---
# POSTGRES_PASSWORD=отдельный_сильный_пароль_не_как_SSH
# APP_PORT=8010
# PostgreSQL снаружи только с localhost сервера (пример — порт 8009):
# POSTGRES_PORT_MAPPING=127.0.0.1:8009:5432

# --- Продакшен / сервер (вы зададите свои значения) ---
# Один хост, приложение и БД в Docker Compose:
# DATABASE_URL=postgresql+psycopg://postgres:ВАШ_ПАРОЛЬ@postgres:5432/adam_delivery
#
# Внешняя БД (managed Postgres):
# DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/adam_delivery

# Порт на хосте при docker compose (профиль app), по умолчанию 8010
# APP_PORT=8010

# Воркеры Gunicorn внутри контейнера (по умолчанию 2)
# WEB_CONCURRENCY=2
# GUNICORN_TIMEOUT=120
